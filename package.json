{
  "name": "mvs-vscode",
  "displayName": "MVS Manager",
  "description": "Multidimensional versioning for projects using mvs-manager (lint, generate, report, doctor).",
  "version": "1.3.2",
  "publisher": "alextheberge",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/alextheberge/mvs-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "keywords": [
    "mvs",
    "versioning",
    "mvs-manager"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/mvs.json",
    "onCommand:mvs.lint",
    "onCommand:mvs.generate",
    "onCommand:mvs.report",
    "onCommand:mvs.doctor",
    "onCommand:mvs.clearDiagnostics",
    "onCommand:mvs.checkForUpdates",
    "onCommand:mvs.statusBarClick",
    "onCommand:mvs.initWorkspace"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "package": "node scripts/package-universal.mjs",
    "mvs:lint": "mvs-manager lint --root . --manifest mvs.json --format text",
    "mvs:generate": "mvs-manager generate --root . --manifest mvs.json --context vscode --format text",
    "mvs:sync-version": "node scripts/sync-version.mjs",
    "mvs:dogfood-check": "node scripts/check-dogfood.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/vsce": "^3.2.0",
    "eslint": "^8.57.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "contributes": {
    "configuration": {
      "title": "MVS Manager",
      "properties": {
        "mvsManager.executablePath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the mvs-manager binary. Leave empty to use `mvs-manager` on PATH."
        },
        "mvsManager.root": {
          "type": "string",
          "default": ".",
          "description": "Project root passed to --root (relative to the workspace folder)."
        },
        "mvsManager.manifest": {
          "type": "string",
          "default": "mvs.json",
          "description": "Manifest path relative to `mvsManager.root` (same as `mvs-manager` doctor/lint/generate)."
        },
        "mvsManager.context": {
          "type": "string",
          "default": "cli",
          "description": "Value for `mvs-manager generate --context`."
        },
        "mvsManager.aiSchema": {
          "type": "string",
          "default": "",
          "description": "Optional path for `mvs-manager --ai-schema` (relative to the workspace folder)."
        },
        "mvsManager.runLintOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run MVS lint when the manifest file (under root) is saved (debounced)."
        },
        "mvsManager.autoUpdate.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Periodically check GitHub for a newer release of this extension (VSIX from the configured repository)."
        },
        "mvsManager.autoUpdate.mode": {
          "type": "string",
          "default": "install",
          "enum": [
            "install",
            "notify"
          ],
          "enumDescriptions": [
            "When a newer version exists, download the release .vsix and install it, then prompt to reload.",
            "Show a notification first; install only if you choose \"Download and install\"."
          ]
        },
        "mvsManager.autoUpdate.intervalHours": {
          "type": "number",
          "default": 24,
          "minimum": 1,
          "description": "How often to re-check GitHub for updates (first check runs shortly after startup)."
        },
        "mvsManager.autoUpdate.releaseApiUrl": {
          "type": "string",
          "default": "",
          "description": "Optional override for the GitHub releases API base URL (no trailing slash), e.g. https://api.github.com/repos/owner/repo. Leave empty to derive owner/repo from package.json repository.url."
        }
      }
    },
    "commands": [
      {
        "command": "mvs.lint",
        "title": "MVS: Lint manifest",
        "category": "MVS"
      },
      {
        "command": "mvs.generate",
        "title": "MVS: Generate / update manifest",
        "category": "MVS"
      },
      {
        "command": "mvs.report",
        "title": "MVS: Report (JSON)",
        "category": "MVS"
      },
      {
        "command": "mvs.doctor",
        "title": "MVS: Doctor",
        "category": "MVS"
      },
      {
        "command": "mvs.clearDiagnostics",
        "title": "MVS: Clear diagnostics",
        "category": "MVS"
      },
      {
        "command": "mvs.checkForUpdates",
        "title": "MVS: Check for extension updates",
        "category": "MVS"
      },
      {
        "command": "mvs.statusBarClick",
        "title": "MVS: Status bar actions",
        "category": "MVS"
      },
      {
        "command": "mvs.initWorkspace",
        "title": "MVS: Initialize manifest (init)",
        "category": "MVS"
      }
    ]
  }
}
